{
  "db_name": "PostgreSQL",
  "query": "SELECT s.id, s.name, s.category,\r\n                      COALESCE(\r\n                          json_agg(json_build_object('id', c.id, 'name', c.name)) FILTER (WHERE c.id IS NOT NULL),\r\n                          '[]'::json\r\n                      ) as \"courses!\"\r\n               FROM subjects s\r\n               LEFT JOIN courses c ON c.subject_id = s.id\r\n               WHERE s.tenant_id = $1\r\n               GROUP BY s.id ORDER BY s.name",
