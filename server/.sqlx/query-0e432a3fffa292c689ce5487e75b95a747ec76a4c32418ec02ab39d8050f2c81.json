  "db_name": "PostgreSQL",
  "query": "\n            SELECT id, tenant_id, user_id, content, parent_id, created_at, updated_at\n            FROM (\n                SELECT id, tenant_id, user_id, content, parent_id, created_at, updated_at\n                FROM group_messages\n                WHERE tenant_id = $1\n                ORDER BY created_at DESC\n                LIMIT 100\n            ) sub\n            ORDER BY created_at ASC\n            ",
