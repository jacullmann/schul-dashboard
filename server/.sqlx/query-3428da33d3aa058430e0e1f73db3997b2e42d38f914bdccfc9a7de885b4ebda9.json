  "query": "\n            SELECT r.name as role_name, g.owner_id, g.permissions\n            FROM user_roles ur\n            JOIN roles r ON r.id = ur.role_id\n            JOIN groups g ON g.id = ur.tenant_id\n            WHERE ur.user_id = $1 AND ur.tenant_id = $2\n            LIMIT 1\n            ",
