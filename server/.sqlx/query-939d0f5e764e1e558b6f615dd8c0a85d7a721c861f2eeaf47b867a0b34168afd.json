{
  "db_name": "PostgreSQL",
  "query": "SELECT s.id, s.name, s.category,\n                      COALESCE(\n                          json_agg(json_build_object('id', c.id, 'name', c.name)) FILTER (WHERE c.id IS NOT NULL),\n                          '[]'::json\n                      ) as \"courses!\"\n               FROM subjects s\n               LEFT JOIN courses c ON c.subject_id = s.id\n               WHERE s.tenant_id = $1\n               GROUP BY s.id ORDER BY s.name",
