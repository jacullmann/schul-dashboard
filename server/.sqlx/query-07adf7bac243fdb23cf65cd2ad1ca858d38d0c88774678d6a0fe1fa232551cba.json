  "query": "SELECT g.name,\n                      g.avatar_url,\n                      (SELECT COUNT(*) FROM user_roles WHERE tenant_id = g.id) AS \"member_count!\"\n               FROM group_invites gi\n               JOIN groups g ON g.id = gi.tenant_id\n               WHERE gi.token = $1 AND gi.expires_at > now()",
