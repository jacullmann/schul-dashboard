  "query": "\n            SELECT\n                g.id, g.name, g.owner_id, g.schedule_config,\n                r.name as role_name\n            FROM user_roles ur\n            JOIN groups g ON g.id = ur.tenant_id\n            JOIN roles r ON r.id = ur.role_id\n            WHERE ur.user_id = $1 AND ur.tenant_id IS NOT NULL\n            ",
