  "db_name": "PostgreSQL",
  "query": "SELECT DISTINCT ON (family_id)\n                      family_id, issued_at, last_used_at, user_agent,\n                      host(ip_address) as ip_address\n               FROM refresh_tokens\n               WHERE user_id = $1\n                 AND revoked_at IS NULL\n                 AND used_at IS NULL\n                 AND expires_at > now()\n               ORDER BY family_id, last_used_at DESC",
