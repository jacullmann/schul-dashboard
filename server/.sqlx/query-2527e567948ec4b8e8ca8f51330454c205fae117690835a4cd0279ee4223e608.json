  "query": "\n            UPDATE password_resets SET attempts = attempts + 1\n            WHERE id = (\n                SELECT id FROM password_resets\n                WHERE email = $1 AND used = false\n                ORDER BY created_at DESC LIMIT 1\n            )\n            RETURNING id, code, expires_at, attempts\n            ",
