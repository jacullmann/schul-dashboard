{
  "db_name": "PostgreSQL",
  "query": "\n            SELECT family_id, issued_at, last_used_at, user_agent, ip_address::text as ip_address\n            FROM refresh_tokens\n            WHERE user_id = $1\n              AND revoked_at IS NULL\n              AND used_at IS NULL\n              AND expires_at > now()\n            ORDER BY last_used_at DESC\n            ",
