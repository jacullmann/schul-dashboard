# Port, Render setzt meist automatisch PORT, aber sicherheitshalber:
PORT=8080

# MongoDB-Verbindung (von Atlas oder eigener Instanz)
MONGODB_URI=

# Admin-Zugang
ADMIN_EMAIL=jannesgiga@giga.giga
ADMIN_PASSWORD=giga
# alternativ statt ADMIN_PASSWORD kannst du auch ADMIN_PASSWORD_HASH setzen (bcrypt-Hash)

# JWT Secret für Tokens (zufälliger langer String)
JWT_SECRET=irgendeinLangerZufallsstring1234567890

# CORS: hier die URL deines Frontends eintragen (Render-URL vom Vue-Frontend)
CORS_ORIGIN=

# DSGVO: falls du IP-Adressen im Klartext speichern willst (true/false)
LOG_IP_RAW=false
