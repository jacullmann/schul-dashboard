PORT=8090
MONGODB_URI=mongodb+srv://<USER>:<PASS>@<CLUSTER>.mongodb.net/hausaufgaben

# CORS: URL deines Frontends
CORS_ORIGIN=https://dein-frontend.onrender.com

# JWT
JWT_SECRET=<starker_langer_random_string>

# SMTP (GMX)
SMTP_HOST=mail.gmx.net
SMTP_PORT=587
SMTP_USER=<deine_gmx_email>@gmx.de
SMTP_PASS=<dein_app_passwort_oder_passwort>
SMTP_FROM="Schulportal <deine_gmx_email>@gmx.de"

# Verifizierungs-Link Ziel (Frontend-URL mit Verify-View)
CLIENT_VERIFY_URL=https://dein-frontend.onrender.com/hausaufgaben/verify

# Cloudinary
CLOUDINARY_CLOUD_NAME=<cloud_name>
CLOUDINARY_API_KEY=<api_key>
CLOUDINARY_API_SECRET=<api_secret>
CLOUDINARY_FOLDER=hausaufgaben
